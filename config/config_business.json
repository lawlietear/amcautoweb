        {
            "key": "fenqi_transition_income",
            "label": "7.4.1条款-分期",
            "type": "text",
            "required": false,
            "category": "合同信息",
            "description": "分期合同填写。1=收入归甲方, 2=收入归乙方(交割日前后分别处理), 3=收入归乙方(交割日前冲抵应付款项)"
        },
        {
            "key": "fenqi_disposal_fee",
            "label": "8.5条款-分期",
            "type": "text",
            "required": false,
            "category": "合同信息",
            "description": "分期合同填写。1=甲方承担, 2=乙方承担(甲方不垫付), 3=乙方承担(经申请甲方可垫付)"
        }
