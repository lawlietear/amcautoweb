{
    "dept_name": "业务部",
    "dept_icon": "💼",
    "filename_pattern": "合同_{contract_no}.docx",
    "templates": {
        "yicixing": {
            "name": "债权转让协议（非分期）",
            "path": "word_templates/template_债权转让协议_非分期.docx",
            "description": "适用于一次性付款的债权转让"
        },
        "fenqi": {
            "name": "债权转让协议（分期）",
            "path": "word_templates/template_债权转让协议_分期处置.docx",
            "description": "适用于分期付款的债权转让"
        }
    },
    "default_template": "yicixing",
    "variables": [
        {
            "key": "contract_no",
            "label": "* 合同编号",
            "type": "text",
            "required": true,
            "category": "合同信息"
        },
        {
            "key": "party_b_name",
            "label": "* 乙方名称（受让方）",
            "type": "text",
            "required": true,
            "category": "合同信息",
            "description": "填写债务人/受让方名称"
        },
        {
            "key": "base_date",
            "label": "* 基准日",
            "type": "text",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制"
        },
        {
            "key": "principal_amount",
            "label": "* 债权本金金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制，自动转大写"
        },
        {
            "key": "interest_amount",
            "label": "* 债权利息金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制，自动转大写"
        },
        {
            "key": "other_fees_amount",
            "label": "* 其他费用金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制，自动转大写"
        },
        {
            "key": "total_claim_amount",
            "label": "* 债权总额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制，自动转大写"
        },
        {
            "key": "deposit_amount",
            "label": "* 保证金金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制，自动转大写"
        },
        {
            "key": "transfer_price",
            "label": "* 转让价格",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "批复信息",
            "description": "可从批复页面复制拟转让价格，自动转大写"
        },
        {
            "key": "remaining_price",
            "label": "剩余交易价款",
