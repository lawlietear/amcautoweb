            "total_claim_amount": true,
            "reserve_price": true,
            "deposit_amount": false,
            "bank_name": false
        },
        "fenqi": {
            "approval_no": true,
            "business_type": true,
            "meeting_date": true,
            "meeting_seq": true,
            "project_name": true,
            "report_name": true,
            "department": true,
