{
    "dept_name": "风险合规部",
    "dept_icon": "⚖️",
    "filename_pattern": "批复_{timestamp}.docx",
    "templates": {
        "yicixing": {
            "name": "一次性业务批复",
            "path": "word_templates/template_一次性业务批复.docx",
            "description": "适用于一次性付款业务"
        },
        "fenqi": {
            "name": "分期处置批复",
            "path": "word_templates/template_分期业务批复.docx",
            "description": "适用于分期付款业务"
        },
        "shougou": {
            "name": "收购业务批复",
            "path": "word_templates/template_收购业务批复.docx",
            "description": "适用于收购业务"
        },
        "shougou_ni": {
            "name": "收购拟处置业务批复",
            "path": "word_templates/template_收购拟处置业务批复.docx",
            "description": "适用于收购拟处置业务"
        }
    },
