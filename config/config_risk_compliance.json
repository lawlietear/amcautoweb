            "total_claim_amount": true,
            "occupancy_rate": true,
            "payment_months": true,
            "final_payment_deadline": true,
            "reserve_price": true,
            "deposit_amount": false,
            "bank_name": false
        },
        "shougou": {
            "approval_no": true,
            "business_type": true,
            "meeting_date": true,
            "meeting_seq": true,
            "project_name": true,
            "report_name": true,
            "department": true,
            "project_leaders": true,
            "debtor_name": true,
            "debtor_count": true,
            "base_date": true,
            "principal_amount": true,
            "interest_amount": true,
            "other_fees_amount": true,
            "total_claim_amount": true,
            "bank_name": true,
            "reserve_price": false,
            "deposit_amount": false
        },
        "shougou_ni": {
            "approval_no": true,
            "business_type": true,
            "meeting_date": true,
            "meeting_seq": true,
            "project_name": true,
            "report_name": true,
            "department": true,
            "project_leaders": true,
            "debtor_name": true,
            "debtor_count": true,
            "base_date": true,
            "principal_amount": true,
            "interest_amount": true,
