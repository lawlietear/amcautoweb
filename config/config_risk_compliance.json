            "total_claim_amount": true,
            "bank_name": true,
            "deposit_amount": true,
            "reserve_price": false
        }
    },
    "variables": [
        {
            "key": "approval_no",
            "label": "* 批复编号",
            "type": "text",
            "required": true,
            "category": "基本信息",
            "default": "",
            "description": "格式：〔年份〕序号，如 〔2026〕007"
        },
        {
            "key": "reviewers",
            "label": "审核人员",
            "type": "text",
            "required": false,
            "category": "基本信息"
        },
        {
            "key": "business_type",
            "label": "* 业务分类",
            "type": "text",
            "required": true,
            "category": "基本信息",
            "default": ""
        },
        {
            "key": "meeting_date",
            "label": "* 会议/审批日",
            "type": "text",
            "required": true,
            "category": "会议信息"
        },
        {
            "key": "meeting_seq",
            "label": "* 会次",
            "type": "text",
            "required": true,
            "category": "会议信息"
        },
        {
            "key": "project_name",
            "label": "* 项目名称",
            "type": "text",
            "required": true,
            "category": "项目信息"
        },
        {
            "key": "report_name",
            "label": "* 尽调报告名称",
            "type": "text",
            "required": true,
            "category": "项目信息"
        },
        {
            "key": "department",
            "label": "* 部门",
            "type": "text",
            "required": true,
            "category": "项目信息"
        },
        {
            "key": "project_leaders",
            "label": "* 项目负责人",
            "type": "text",
            "required": true,
            "category": "项目信息"
        },
        {
            "key": "debtor_name",
            "label": "* 债务人名称",
            "type": "text",
            "required": true,
            "category": "债务人信息"
        },
        {
            "key": "debtor_count",
            "label": "* 户数",
            "type": "text",
            "required": true,
            "category": "债务人信息",
            "default": ""
        },
        {
            "key": "base_date",
            "label": "* 基准日",
            "type": "text",
            "required": true,
            "category": "业务信息"
        },
        {
            "key": "principal_amount",
            "label": "* 债权本金金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "金额信息"
        },
        {
            "key": "interest_amount",
            "label": "* 利息金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "金额信息"
        },
        {
            "key": "other_fees_amount",
            "label": "* 其他费用金额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "金额信息"
        },
        {
            "key": "total_claim_amount",
            "label": "* 债权总额",
            "type": "numeric",
            "format": "thousand",
            "required": true,
            "category": "金额信息"
        },
        {
            "key": "reserve_price",
            "label": "拟转让价格（元）",
            "type": "numeric",
            "format": "thousand",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "fee_bearer",
            "label": "交易费用承担主体",
            "type": "text",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "deposit_amount",
            "label": "保证金金额（元）",
            "type": "numeric",
            "format": "thousand",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "remaining_amount",
            "label": "剩余交易价款金额（元）",
            "type": "numeric",
            "format": "thousand",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "final_payment_deadline",
            "label": "尾款支付期限",
            "type": "text",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "occupancy_rate",
            "label": "资金占用费率",
            "type": "text",
            "required": false,
            "category": "交易信息"
        },
        {
            "key": "payment_months",
            "label": "分期付款月数",
            "type": "text",
            "required": false,
            "category": "交易信息",
            "description": "分期处置时填写，如：12个月"
        },
        {
            "key": "bank_name",
            "label": "* 银行名称",
            "type": "text",
            "required": false,
            "category": "债务人信息",
            "description": "收购业务模板需要"
        },
        {
            "key": "approval_date",
            "label": "批复日期",
            "type": "text",
            "readonly": true,
            "category": "业务信息",
            "auto": "current_date",
            "description": "自动生成：当前日期"
        }
    ],
